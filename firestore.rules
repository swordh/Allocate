rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ─────────────────────────────────────────────────────────
    // Users may read their own profile. All writes are via Cloud Functions only.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Memberships ───────────────────────────────────────────────────────────
    // Users may read their own membership documents (needed for company switcher).
    // All writes are via Cloud Functions only — prevents self-elevation to admin.
    match /users/{userId}/memberships/{companyId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Company root document ─────────────────────────────────────────────────
    // All company writes are via Cloud Functions only.
    // Subscription state is Stripe's source of truth and must never be
    // written directly by a client.
    match /companies/{companyId} {
      allow read: if request.auth != null
                  && request.auth.token.activeCompanyId == companyId;
      allow write: if false;
    }

    // ── Equipment ─────────────────────────────────────────────────────────────
    // All writes are via Cloud Functions only (addEquipment, updateEquipment,
    // deactivateEquipment). The client never writes equipment documents directly.
    match /companies/{companyId}/equipment/{equipmentId} {
      allow read: if request.auth != null
                  && request.auth.token.activeCompanyId == companyId;
      allow write: if false; // Cloud Functions only
    }

    // ── Equipment units subcollection (collectionGroup access) ───────────────
    // collectionGroup('units') queries cannot match path-specific rules.
    // This wildcard rule enables client-side real-time listeners while keeping
    // tenant isolation via the denormalized companyId field on each unit doc.
    match /{path=**}/units/{unitId} {
      allow read: if request.auth != null
                  && request.auth.token.activeCompanyId == resource.data.companyId;
      allow write: if false;
    }

    // ── Equipment units subcollection ─────────────────────────────────────────
    // Physical unit documents live under equipment/{equipmentId}/units/{unitId}.
    // All writes are via Server Actions (Admin SDK) only.
    match /companies/{companyId}/equipment/{equipmentId}/units/{unitId} {
      allow read: if request.auth != null
                  && request.auth.token.activeCompanyId == companyId;
      allow write: if false;  // Server Actions (admin SDK) only
    }

    // ── Categories ────────────────────────────────────────────────────────────
    // All writes are via Cloud Functions only (addCategory, seeded by createCompany).
    match /companies/{companyId}/categories/{categoryId} {
      allow read: if request.auth != null
                  && request.auth.token.activeCompanyId == companyId;
      allow write: if false; // Cloud Functions only
    }

    // ── Bookings ───────────────────────────────────────────────────────────────
    // All writes are via Cloud Functions only (createBooking, updateBooking,
    // cancelBooking, approveBooking, rejectBooking, updateBookingStatus).
    // The companyId claim check ensures tenant isolation — a user can only read
    // bookings for the company they are currently active in.
    match /companies/{companyId}/bookings/{bookingId} {
      allow read: if request.auth != null
                  && request.auth.token.activeCompanyId == companyId;
      allow write: if false; // Cloud Functions only
    }

    // ── Nested company data (fallback for future subcollections) ──────────────
    // Covers any subcollection not yet given its own explicit rule above.
    // Phase 3 will add a specific bookings rule (crew can create their own).
    // This wildcard must remain as a safe fallback — read for members, no writes.
    match /companies/{companyId}/{document=**} {
      allow read: if request.auth != null
                  && request.auth.token.activeCompanyId == companyId;
      allow write: if false; // Default: all writes via Cloud Functions
    }

    // ── Stripe event deduplication log ────────────────────────────────────────
    // Written only by the webhook Cloud Function. Never readable by clients.
    match /_stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // ── GDPR deletion audit log ───────────────────────────────────────────────
    // Written only by the deleteAccount Cloud Function. Never readable by clients.
    match /deletionAuditLog/{logId} {
      allow read, write: if false;
    }
  }
}
